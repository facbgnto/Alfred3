API_PORT=34777
WEB_ORIGIN=http://localhost:5174
DATABASE_URL=postgresql://alfred:alfred@localhost:5432/alfred

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_VOICE_MODEL=llama3.2:3b
OLLAMA_FALLBACK_MODEL=llama3.2:3b
OLLAMA_STREAM=true
OLLAMA_TIMEOUT_MS=120000
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_CTX=8192

VOICE_SERVICE_URL=http://127.0.0.1:8765
VOICE_STT_BASE_URL=http://127.0.0.1:8765
VOICE_STT_PROVIDER=faster-whisper
VOICE_STT_MODEL=small
VOICE_STT_LANGUAGE=es
VOICE_STT_DEVICE=auto
VOICE_STT_COMPUTE_TYPE=int8
VOICE_STT_TIMEOUT_MS=20000
VOICE_STT_AUTO_START=true
VOICE_STT_FALLBACK_ENABLED=true
VOICE_MAX_AUDIO_BYTES=26214400

VOICE_WAKE_WORD_ENABLED=true
VOICE_WAKE_WORD=alfred
VOICE_WAKE_WORD_THRESHOLD=0.65
VOICE_WAKE_WORD_COOLDOWN_MS=2000
# Vacio = usa el modelo generico "hey_jarvis" de openWakeWord (no hay modelo oficial
# para "alfred", hay que entrenar uno propio; ver docs/VOICE_PROVIDERS.md). Opcional:
# si openWakeWord no esta instalado (apps/voice-service/requirements-wakeword.txt),
# el wake word cae automaticamente a deteccion por transcripcion (comportamiento previo).
VOICE_WAKE_WORD_MODEL_PATH=

VOICE_VAD_ENABLED=true
VOICE_VAD_THRESHOLD=0.5
VOICE_VAD_MIN_SPEECH_MS=250
VOICE_VAD_SILENCE_MS=600
VOICE_VAD_MAX_RECORDING_MS=30000
VOICE_VAD_PREBUFFER_MS=300
VOICE_VAD_POSTBUFFER_MS=200

VOICE_TTS_PROVIDER=piper
VOICE_TTS_VOICE=es_male
VOICE_TTS_LANGUAGE=es
VOICE_TTS_SPEED=0.96
VOICE_TTS_STREAM=true
VOICE_TTS_FALLBACK_PROVIDER=pyttsx3
# Modelo Piper local (ruta relativa a apps/voice-service, o absoluta). Preferir modelos
# "high" quality sobre "medium"/"x_low" cuando esten disponibles: suenan bastante menos
# roboticos. Ver apps/voice-service/voices/ para los modelos ya descargados.
VOICE_TTS_PIPER_MODEL=voices/es_MX-claude-high.onnx
# Semitonos a bajar el tono (via librosa phase vocoder) para una voz mas grave. Valores
# grandes (por ejemplo -6) generan artefactos metalicos/roboticos notorios; -2 a -3 es
# un rango mas seguro para "grave pero natural".
VOICE_TTS_PITCH_SHIFT=-2

VOICE_BARGE_IN_ENABLED=true
VOICE_STOP_COMMANDS=detente,silencio,cancela,para
VOICE_NOISE_SUPPRESSION=true
VOICE_ECHO_CANCELLATION=true
VOICE_AUTO_GAIN_CONTROL=true

# Modo de voz por defecto (ver docs/VOICE_PROVIDERS.md): normal, conversation,
# programming, explanation, navigation, reminder, alarm, music, error, celebration.
VOICE_MODE=conversation

# Segmentador de streaming TTS (oracion por oracion mientras el LLM sigue generando).
VOICE_MIN_SEGMENT_CHARS=35
VOICE_MAX_SEGMENT_CHARS=220
VOICE_SEGMENT_TIMEOUT_MS=350

# Cache de audio ya sintetizado (SHA-256 de texto+proveedor+voz+velocidad+idioma).
VOICE_CACHE=true
VOICE_CACHE_TTL_HOURS=168
VOICE_CACHE_MAX_MB=500

# --- Proveedores en la nube (opcionales, deshabilitados por defecto) ---
# Alfred es local-first: sin API key configurada, healthCheck reporta "not_configured"
# y VoiceManager nunca los selecciona salvo que VOICE_TTS_PROVIDER los pida explicitamente
# y esten configurados. Ver docs/VOICE_PROVIDERS.md antes de activar cualquiera de estos.
OPENAI_API_KEY=
OPENAI_TTS_MODEL=
OPENAI_TTS_VOICE=

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0
ELEVENLABS_SPEAKER_BOOST=true
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL_ID=sonic-2

# --- Proveedores locales adicionales (opcionales) ---
KOKORO_BASE_URL=http://127.0.0.1:8880
XTTS_BASE_URL=http://127.0.0.1:8020
# Nombre del archivo (sin extension) dentro de apps/voice-service/xtts-samples/, no una
# ruta. Ej.: si el archivo autorizado es xtts-samples/alfred.wav, poner XTTS_SPEAKER_ID=alfred.
# Ver docs/VOICE_PROVIDERS.md#xtts-v2-local-experimental para instalar y arrancar el servidor.
XTTS_SPEAKER_ID=

ALFRED_USER_NAME=Felipe
ALFRED_ADDRESS=senor
